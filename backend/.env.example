# =============================================================================
# YanGuan-NLP 环境变量配置模板
# 复制此文件为 .env 并修改对应值
# =============================================================================

# --- 数据目录 ---
# 存放停用词、自定义词典、同义词表等资源文件
GC_DATA_DIR=backend/data

# --- 数据库 ---
# SQLite 数据库连接 URL（使用 aiosqlite 异步驱动）
GC_DATABASE_URL=sqlite+aiosqlite:///./gradcareer.db

# --- 资源文件路径（可选） ---
# 若不设置，默认从 GC_DATA_DIR 下查找对应文件
# GC_STOPWORDS_PATH=
# GC_CUSTOM_DICT_PATH=
# GC_SYNONYM_PATH=

# --- BERTopic 模型 ---
# 本地 SentenceTransformer Embedding 模型路径
# 推荐 BGE-small-zh-v1.5（中文优化，512维，~95MB）
# 下载: git clone https://huggingface.co/BAAI/bge-small-zh-v1.5
# GC_BERTOPIC_MODEL_PATH=/home/wg/models/bge-small-zh-v1.5
#
# 备选：在线模型名称（自动下载并缓存到 GC_DATA_DIR/model/text2vec/）
# GC_BERTOPIC_MODEL_NAME=shibing624/text2vec-base-chinese

# --- 分词器 ---
# 可选值: jieba (默认) | pkuseg
# pkuseg 使用 web 模型，对 B 站网络文本分词更准确，支持词性过滤
# GC_TOKENIZER_BACKEND=jieba

# --- 短文本聚合 ---
# 是否启用视频+时间窗口聚合（缓解短文本语义稀疏）
# GC_AGGREGATION_ENABLED=false
# 聚合时间窗口大小（分钟）
# GC_AGGREGATION_WINDOW_MINUTES=60
# 聚合组最少评论数（低于此值被丢弃）
# GC_AGGREGATION_MIN_COMMENTS=3

# --- Ollama 配置（用于 LLM 主题命名精炼） ---
# GC_OLLAMA_BASE_URL=http://localhost:11434
# GC_OLLAMA_MODEL=qwen2.5:3b   # 无 thinking 模式，比 qwen3:4b 更快
# GC_OLLAMA_TIMEOUT=60.0       # 无 thinking 模式响应更快，60s 足够
# GC_LLM_BATCH_SIZE=10         # 无 thinking 模式可增大批处理
# GC_LLM_NUM_CTX=4096          # 限制上下文窗口加速推理

# --- 服务配置 ---
# GC_HOST=0.0.0.0
# GC_PORT=3001
# GC_LOG_LEVEL=INFO

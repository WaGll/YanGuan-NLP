# =============================================================================
# GradCareer-CommentAnalysis 环境变量配置模板
# 复制此文件为 .env 并修改对应值
# =============================================================================

# --- 数据目录 ---
# 存放停用词、自定义词典、同义词表等资源文件
GC_DATA_DIR=backend/data

# --- 数据库 ---
# SQLite 数据库连接 URL（使用 aiosqlite 异步驱动）
GC_DATABASE_URL=sqlite+aiosqlite:///./gradcareer.db

# --- 资源文件路径（可选） ---
# 若不设置，默认从 GC_DATA_DIR 下查找对应文件
# GC_STOPWORDS_PATH=
# GC_CUSTOM_DICT_PATH=
# GC_SYNONYM_PATH=

# --- 服务配置 ---
# GC_HOST=0.0.0.0
# GC_PORT=8000
# GC_LOG_LEVEL=INFO
